---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
	<section class="hero">
		<div class="hero-inner">
			<h1>Winston-Salem's Premier Auto Repair Shop</h1>
			<p class="lead">Honest car repair, maintenance, and diagnostics. Fast turnarounds — fair prices.</p>
			<a class="btn" href="/contact">Book Appointment</a>
		</div>
	</section>

	<section class="overview">
		<div class="container grid">
			<div class="card">
				<h2>Comprehensive Repairs</h2>
				<p>From brakes and transmissions to electrical diagnostics — we fix it right the first time.</p>
			</div>
			<div class="card">
				<h2>Maintenance</h2>
				<p>Oil changes, inspections, and routine service to keep your vehicle running safely.</p>
			</div>
			<div class="card">
				<h2>Diagnostics</h2>
				<p>Modern scan tools to quickly identify issues and provide transparent estimates.</p>
			</div>
		</div>
	</section>
</Layout>
